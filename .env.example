# ============================================================
# VARIABLES DE ENTORNO - I.E. Manuel Scorza Sistema de Gestión
# ============================================================
# Copia este archivo como .env.local para desarrollo local
# En Vercel, configura estas variables en el panel de Settings > Environment Variables

# Base de datos PostgreSQL (Neon)
# Obtén esta URL desde tu panel de Neon → Proyecto → Connection String
DATABASE_URL=postgresql://usuario:contraseña@ep-xxxxx.region.aws.neon.tech/nombre_db?sslmode=require

# Secreto para firmar los JWT de sesión
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_de_al_menos_64_caracteres

# Entorno (Vercel lo configura automáticamente)
# NODE_ENV=production
